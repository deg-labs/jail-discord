# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token

# Auto role batch
AUTO_ROLE_TARGET_ROLE=testrole
AUTO_ROLE_TARGET_KEYWORD=userid
# comma-separated Discord user IDs to skip
AUTO_ROLE_EXCLUDED_USER_IDS=
AUTO_ROLE_INTERVAL_MINUTES=5
AUTO_ROLE_BLACK_LUMINANCE_THRESHOLD=8
AUTO_ROLE_BLACK_RATIO_THRESHOLD=0.98
AUTO_ROLE_TRANSPARENT_ALPHA_THRESHOLD=16
AUTO_ROLE_TRANSPARENT_RATIO_THRESHOLD=0.98
AUTO_ROLE_VERBOSE_LOGGING=true

# Runtime
PORT=8080
